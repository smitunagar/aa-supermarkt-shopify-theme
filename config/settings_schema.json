[
  {
    "name": "theme_info",
    "theme_name": "A&A International Supermarkt",
    "theme_version": "1.0.0",
    "theme_author": "A&A International",
    "theme_documentation_url": "https://github.com/smitunagar/aa-supermarkt-theme",
    "theme_support_url": "mailto:info@aa-supermarkt.de"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary colour (Forest Green)",
        "default": "#0F3F25"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent colour (Saffron Orange)",
        "default": "#E07C39"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "type_header_font",
        "label": "Heading font",
        "options": [
          { "value": "playfair", "label": "Playfair Display" },
          { "value": "inter", "label": "Inter" },
          { "value": "georgia", "label": "Georgia" }
        ],
        "default": "playfair"
      },
      {
        "type": "range",
        "id": "type_base_size",
        "min": 13,
        "max": 18,
        "step": 1,
        "default": 15,
        "unit": "px",
        "label": "Base font size"
      }
    ]
  },
  {
    "name": "Currency",
    "settings": [
      {
        "type": "select",
        "id": "currency_format",
        "label": "Currency format",
        "options": [
          { "value": "money_with_currency", "label": "€10.00 EUR" },
          { "value": "money", "label": "€10.00" }
        ],
        "default": "money_with_currency"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      { "type": "url", "id": "social_instagram_link", "label": "Instagram" },
      { "type": "url", "id": "social_facebook_link", "label": "Facebook" },
      { "type": "url", "id": "social_tiktok_link", "label": "TikTok" }
    ]
  }
]
