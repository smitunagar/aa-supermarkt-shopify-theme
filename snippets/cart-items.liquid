<div id="cart-items-inner">
{%- if cart.item_count == 0 -%}
  <div class="text-center py-16">
    <p class="text-5xl mb-4">🛒</p>
    <p class="text-stone-500 font-medium mb-4">Your cart is empty</p>
    <a href="/collections/all" class="inline-flex items-center gap-1.5 text-sm font-medium text-forest-700 hover:text-forest-900 transition-colors">
      Start shopping
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>
  </div>
{%- else -%}
  {%- for item in cart.items -%}
    <div class="flex gap-3" data-cart-item data-key="{{ item.key }}">

      <!-- Image -->
      <a href="{{ item.url }}" class="flex-shrink-0 w-16 h-16 rounded-xl overflow-hidden bg-warm-100">
        {%- if item.image -%}
          <img src="{{ item.image | image_url: width: 128 }}"
               alt="{{ item.title | escape }}"
               class="w-full h-full object-cover">
        {%- else -%}
          <div class="w-full h-full flex items-center justify-center text-2xl">🛍️</div>
        {%- endif -%}
      </a>

      <!-- Details -->
      <div class="flex-1 min-w-0">
        <a href="{{ item.url }}"
           class="text-sm font-medium text-stone-800 hover:text-forest-700 line-clamp-2 transition-colors block">
          {{ item.product.title }}
        </a>
        {%- unless item.product.has_only_default_variant -%}
          <p class="text-xs text-stone-400 mt-0.5">{{ item.variant.title }}</p>
        {%- endunless -%}

        <div class="flex items-center justify-between mt-2">

          <!-- Qty controls -->
          <div class="flex items-center gap-1.5">
            <button class="cart-qty-btn w-6 h-6 rounded-full border border-stone-200 flex items-center justify-center text-xs font-medium hover:border-forest-600 hover:text-forest-700 transition-colors"
                    data-key="{{ item.key }}"
                    data-qty="{{ item.quantity | minus: 1 }}"
                    aria-label="Decrease quantity">
              −
            </button>
            <span class="text-sm font-semibold w-5 text-center">{{ item.quantity }}</span>
            <button class="cart-qty-btn w-6 h-6 rounded-full border border-stone-200 flex items-center justify-center text-xs font-medium hover:border-forest-600 hover:text-forest-700 transition-colors"
                    data-key="{{ item.key }}"
                    data-qty="{{ item.quantity | plus: 1 }}"
                    aria-label="Increase quantity">
              +
            </button>
          </div>

          <!-- Line price -->
          <p class="text-sm font-bold text-forest-700">{{ item.final_line_price | money }}</p>
        </div>
      </div>

    </div>
  {%- endfor -%}
{%- endif -%}
</div>
