<div class="hero-carousel relative" id="hero-carousel">

  <!-- ── Slide 1: Full-bleed with text overlay ── -->
  <div class="hero-slide active" data-index="0">
    <section class="relative overflow-hidden" style="height:clamp(280px,45vw,520px)">
      <!-- Background image -->
      <img src="{{ 'hero-banner-1.png' | asset_url }}" alt="A&A International Supermarkt" class="absolute inset-0 w-full h-full object-cover object-center">
      <!-- Gradient veil for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent"></div>
      <!-- Text content -->
      <div class="absolute inset-0 flex items-center">
        <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 w-full">
          <div class="max-w-xl">
            <div class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm border border-white/30 text-white text-xs font-semibold rounded-full px-3 py-1 mb-4">
              🛒 Welcome to A&A
            </div>
            <h1 class="font-display font-bold text-white leading-[1.1] tracking-tight mb-3" style="font-size:clamp(1.6rem,4vw,3.2rem)">
              Authentic Indian &amp;<br>International Groceries
            </h1>
            <p class="text-white/85 mb-5" style="font-size:clamp(0.85rem,1.5vw,1rem)">Over 2,000 products from India &amp; the world — delivered across Germany</p>
            <div class="flex flex-wrap items-center gap-3">
              <a href="{{ section.settings.cta_primary_url | default: routes.all_products_collection_url }}"
                 class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white text-sm font-bold px-6 py-3 rounded-full transition-all shadow-lg">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                Shop Now
              </a>
              <span class="text-xs font-bold text-white bg-amber-500 px-3 py-1.5 rounded-full shadow">Free delivery over €50</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ── Slide 2: Pure image, no text ── -->
  <div class="hero-slide" data-index="1" style="display:none">
    <section class="relative overflow-hidden" style="height:clamp(280px,45vw,520px)">
      <img src="{{ 'hero-banner-2.png' | asset_url }}" alt="A&A seasonal collection" class="w-full h-full object-cover object-center">
    </section>
  </div>

  <!-- Prev / Next arrows -->
  <button class="hero-prev absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/80 hover:bg-white shadow-md flex items-center justify-center z-20 transition-all" aria-label="Previous slide">
    <svg class="w-4 h-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <button class="hero-next absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/80 hover:bg-white shadow-md flex items-center justify-center z-20 transition-all" aria-label="Next slide">
    <svg class="w-4 h-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  </button>

  <!-- Dot nav -->
  <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-1.5 z-20">
    <button class="hero-dot active-dot w-5 h-2 rounded-full bg-amber-400 transition-all" data-index="0" aria-label="Slide 1"></button>
    <button class="hero-dot w-2 h-2 rounded-full bg-white/50 hover:bg-white/80 transition-all" data-index="1" aria-label="Slide 2"></button>
  </div>

</div>

<script>
(function() {
  var carousel = document.getElementById('hero-carousel');
  if (!carousel) return;
  var slides = carousel.querySelectorAll('.hero-slide');
  var dots   = carousel.querySelectorAll('.hero-dot');
  var current = 0;
  var timer;

  function goTo(i) {
    slides[current].style.display = 'none';
    dots[current].classList.remove('active-dot');
    dots[current].style.width = '0.5rem';
    dots[current].style.background = 'rgba(255,255,255,0.5)';
    current = i;
    slides[current].style.display = '';
    dots[current].classList.add('active-dot');
    dots[current].style.width = '1.25rem';
    dots[current].style.background = '#fbbf24';
  }

  function next() { goTo((current + 1) % slides.length); }
  function prev() { goTo((current - 1 + slides.length) % slides.length); }

  carousel.querySelector('.hero-next').addEventListener('click', function() { clearInterval(timer); next(); timer = setInterval(next, 6000); });
  carousel.querySelector('.hero-prev').addEventListener('click', function() { clearInterval(timer); prev(); timer = setInterval(next, 6000); });
  dots.forEach(function(d) {
    d.addEventListener('click', function() { clearInterval(timer); goTo(parseInt(d.dataset.index)); timer = setInterval(next, 6000); });
  });

  timer = setInterval(next, 6000);
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "url", "id": "cta_primary_url", "label": "Shop Now button link" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
    { "type": "text", "id": "badge", "label": "Badge text", "default": "Frankfurt's International Market" },
    { "type": "text", "id": "headline_line1", "label": "Headline line 1", "default": "Taste the World," },
    { "type": "text", "id": "headline_line2", "label": "Headline line 2", "default": "Shop" },
    { "type": "text", "id": "headline_accent", "label": "Headline accent (italic saffron)", "default": "from Home" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Over 200 authentic products from Afghanistan, Turkey, India, the Middle East and beyond. Fresh. Quality. Delivered." },
    { "type": "text", "id": "cta_primary", "label": "Primary button text", "default": "Shop Now" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary button link" },
    { "type": "text", "id": "cta_secondary", "label": "Secondary button text", "default": "New Arrivals" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary button link" },
    { "type": "text", "id": "stat1_value", "label": "Stat 1 value", "default": "200+" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 label", "default": "Products" },
    { "type": "text", "id": "stat2_value", "label": "Stat 2 value", "default": "50,000+" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 label", "default": "Happy Customers" },
    { "type": "text", "id": "stat3_value", "label": "Stat 3 value", "default": "4.9 ★" },
    { "type": "text", "id": "stat3_label", "label": "Stat 3 label", "default": "Rating" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
