<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Collection header -->
  <div class="mb-8 fade-up">
    <nav class="flex items-center gap-2 text-xs text-stone-400 mb-4">
      <a href="/" class="hover:text-forest-700 transition-colors">Home</a>
      <span>/</span>
      <span class="text-stone-600">{{ collection.title }}</span>
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div>
        <h1 class="font-display font-bold text-3xl sm:text-4xl text-forest-900">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p class="text-stone-500 mt-2 max-w-lg text-sm leading-relaxed">{{ collection.description }}</p>
        {%- endif -%}
        <p class="text-xs text-stone-400 mt-2">{{ collection.products_count }} products</p>
      </div>

      <!-- Sort -->
      <div class="flex-shrink-0">
        <form>
          <select name="sort_by" class="text-sm border border-warm-200 rounded-xl px-3 py-2 bg-white text-stone-600 focus:outline-none focus:ring-2 focus:ring-forest-600 cursor-pointer"
                  onchange="this.form.submit()">
            <option value="manual" {%- if collection.sort_by == 'manual' %} selected{%- endif %}>Featured</option>
            <option value="best-selling" {%- if collection.sort_by == 'best-selling' %} selected{%- endif %}>Best Selling</option>
            <option value="price-ascending" {%- if collection.sort_by == 'price-ascending' %} selected{%- endif %}>Price: Low → High</option>
            <option value="price-descending" {%- if collection.sort_by == 'price-descending' %} selected{%- endif %}>Price: High → Low</option>
            <option value="created-descending" {%- if collection.sort_by == 'created-descending' %} selected{%- endif %}>Newest First</option>
          </select>
        </form>
      </div>
    </div>
  </div>

  <div class="flex gap-8">

    <!-- Sidebar filters (desktop) -->
    <aside class="hidden lg:block w-56 flex-shrink-0">
      <div class="sticky top-24 space-y-6">

        <!-- All collections -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">Categories</h3>
          <ul class="space-y-1.5">
            <li>
              <a href="/collections/all"
                 class="block text-sm py-1 transition-colors {%- if collection.handle == 'all' %} text-forest-700 font-semibold{%- else %} text-stone-500 hover:text-forest-700{%- endif %}">
                All Products
              </a>
            </li>
            {%- for col in collections -%}
              {%- unless col.handle == 'frontpage' or col.handle == 'all' -%}
                <li>
                  <a href="{{ col.url }}"
                     class="block text-sm py-1 transition-colors {%- if col.handle == collection.handle %} text-forest-700 font-semibold{%- else %} text-stone-500 hover:text-forest-700{%- endif %}">
                    {{ col.title }}
                    <span class="text-stone-300 ml-1 text-xs">({{ col.products_count }})</span>
                  </a>
                </li>
              {%- endunless -%}
            {%- endfor -%}
          </ul>
        </div>

        <!-- Price filter placeholder -->
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">Price</h3>
          <div class="space-y-1.5">
            <a href="{{ collection.url }}?sort_by=price-ascending" class="block text-sm text-stone-500 hover:text-forest-700 py-1 transition-colors">Under €5</a>
            <a href="{{ collection.url }}?sort_by=price-ascending" class="block text-sm text-stone-500 hover:text-forest-700 py-1 transition-colors">€5 – €15</a>
            <a href="{{ collection.url }}?sort_by=price-ascending" class="block text-sm text-stone-500 hover:text-forest-700 py-1 transition-colors">€15 – €30</a>
            <a href="{{ collection.url }}?sort_by=price-descending" class="block text-sm text-stone-500 hover:text-forest-700 py-1 transition-colors">Over €30</a>
          </div>
        </div>

      </div>
    </aside>

    <!-- Products grid -->
    <div class="flex-1">

      {%- paginate collection.products by 20 -%}

        {%- if collection.products.size > 0 -%}
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-5">
            {%- for product in collection.products -%}
              {%- render 'product-card', product: product -%}
            {%- endfor -%}
          </div>

          <!-- Pagination -->
          {%- if paginate.pages > 1 -%}
            <div class="mt-12 flex items-center justify-center gap-2">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="page-link">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                  </svg>
                </a>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="page-link">{{ part.title }}</a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span class="page-link current">{{ part.title }}</span>
                  {%- else -%}
                    <span class="page-link opacity-50 cursor-default">{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="page-link">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- else -%}
          <div class="text-center py-24">
            <p class="text-5xl mb-4">🔍</p>
            <h3 class="font-semibold text-stone-700 mb-2">No products found</h3>
            <p class="text-stone-400 text-sm mb-6">Try browsing all products instead.</p>
            <a href="/collections/all" class="inline-flex items-center gap-1.5 text-sm font-medium text-white bg-forest-700 hover:bg-forest-800 px-5 py-2.5 rounded-2xl transition-colors">
              Browse all
            </a>
          </div>
        {%- endif -%}

      {%- endpaginate -%}

    </div>
  </div>

</div>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
