<footer class="bg-forest-900 text-white">

  <!-- Main footer grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <div class="mb-5">
          <img src="{{ 'logo.jpeg' | asset_url }}" alt="{{ shop.name }}" class="h-12 w-auto object-contain brightness-0 invert">
        </div>
        <p class="text-forest-300 text-sm leading-relaxed mb-5">
          {{ section.settings.tagline | default: "Your premium destination for authentic international groceries in Frankfurt am Main. From Afghan sauces to Turkish pantry staples." }}
        </p>
        <div class="flex items-center gap-1 text-sm text-forest-300 mb-1">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>{{ section.settings.address | default: "Frankfurt am Main, Germany" }}</span>
        </div>
        {%- if section.settings.phone != blank -%}
          <div class="flex items-center gap-1 text-sm text-forest-300">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span>{{ section.settings.phone }}</span>
          </div>
        {%- endif -%}

        <!-- Opening hours -->
        <div class="mt-5 pt-4 border-t border-forest-800">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-forest-500 mb-2.5">Opening Hours</p>
          <div class="space-y-1.5 text-xs text-forest-300">
            <div class="flex justify-between"><span>Mon – Fri</span><span class="font-medium text-forest-200">09:00 – 20:00</span></div>
            <div class="flex justify-between"><span>Saturday</span><span class="font-medium text-forest-200">09:00 – 21:00</span></div>
            <div class="flex justify-between"><span>Sunday</span><span class="font-medium text-forest-200">10:00 – 18:00</span></div>
          </div>
        </div>

        <!-- WhatsApp -->
        {%- if section.settings.whatsapp_number != blank -%}
          <a href="https://wa.me/{{ section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}"
             target="_blank" rel="noopener"
             class="mt-4 inline-flex items-center gap-2 text-xs text-forest-300 hover:text-saffron-400 transition-colors">
            <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp us
          </a>
        {%- endif -%}

      </div>

      <!-- Shop categories -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-forest-300 mb-5">Shop</h3>
        <ul class="space-y-2.5">
          {%- assign shop_links = linklists[section.settings.footer_shop_menu] -%}
          {%- if shop_links.links.size > 0 -%}
            {%- for link in shop_links.links -%}
              <li>
                <a href="{{ link.url }}" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- assign default_cats = "Fresh Produce,Dairy & Eggs,Meat & Poultry,Spices & Herbs,Pantry Staples,Beverages,Snacks & Sweets,Frozen Foods" | split: "," -%}
            {%- for cat in default_cats -%}
              <li>
                <a href="/collections/{{ cat | handle }}" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">{{ cat }}</a>
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>

      <!-- Info links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-forest-300 mb-5">Information</h3>
        <ul class="space-y-2.5">
          {%- assign info_links = linklists[section.settings.footer_info_menu] -%}
          {%- if info_links.links.size > 0 -%}
            {%- for link in info_links.links -%}
              <li>
                <a href="{{ link.url }}" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/pages/about" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">About Us</a></li>
            <li><a href="/pages/delivery" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">Delivery Info</a></li>
            <li><a href="/pages/returns" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">Returns Policy</a></li>
            <li><a href="/pages/contact" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">Contact Us</a></li>
            <li><a href="/pages/privacy-policy" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">Privacy Policy</a></li>
            <li><a href="/pages/faq" class="text-sm text-forest-200 hover:text-saffron-400 transition-colors">FAQ</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-forest-300 mb-5">Stay Updated</h3>
        <p class="text-sm text-forest-300 mb-4">Get weekly deals, new arrivals and recipes straight to your inbox.</p>
        <form id="footer-newsletter" class="space-y-2" action="/contact#contact_form" method="post">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <div class="relative">
            <input type="email" name="contact[email]" placeholder="your@email.com"
                   class="w-full px-4 py-2.5 text-sm bg-forest-800 border border-forest-700 rounded-xl text-white placeholder-forest-400 focus:outline-none focus:ring-2 focus:ring-saffron-400 focus:border-transparent transition-all">
          </div>
          <button type="submit"
                  class="w-full py-2.5 bg-saffron-500 hover:bg-saffron-600 text-white font-semibold text-sm rounded-xl transition-colors">
            Subscribe
          </button>
        </form>

        <!-- Social icons -->
        {%- if section.settings.instagram_url != blank or section.settings.facebook_url != blank -%}
          <div class="flex items-center gap-3 mt-5">
            {%- if section.settings.instagram_url != blank -%}
              <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener"
                 class="w-9 h-9 bg-forest-800 hover:bg-saffron-500 rounded-full flex items-center justify-center transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.facebook_url != blank -%}
              <a href="{{ section.settings.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener"
                 class="w-9 h-9 bg-forest-800 hover:bg-saffron-500 rounded-full flex items-center justify-center transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-forest-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-forest-400">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <img src="{{ 'payment-icons.svg' | asset_url }}" alt="Accepted payment methods" class="h-6 opacity-60" onerror="this.style.display='none'">
        <div class="flex items-center gap-2 text-forest-500">
          <!-- Visa -->
          <svg class="h-5 opacity-60" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="4" fill="#1A1F71"/><path d="M15.7 7.2L13 16.8h2.2l2.7-9.6H15.7zm8.6 6.2l1.1-3.3.6 3.3H24.3zm2.4 3.4H29l-1.7-9.6h-2c-.5 0-.9.3-1.1.7L20.7 16.8H23l.5-1.4H26l.3 1.4zm-9.5-9.6l-3.3 6.6-.4-2-.3-1.4c-.5-1.2-1.5-2.1-2.7-2.5H14c.1 0 .3.1.5.1l3.2 8.9L20 16.8l4-9.6H17.2zm-6.1 0H9l-.1.3c1.9.5 3.2 1.5 3.7 2.8l-.5-2.4c-.1-.4-.4-.7-.8-.7H11z" fill="white"/></svg>
          <!-- Mastercard -->
          <svg class="h-5 opacity-60" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg"><rect width="38" height="24" rx="4" fill="#252525"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="23" cy="12" r="7" fill="#F79E1B"/><path d="M19 6.8a7 7 0 000 10.4A7 7 0 0019 6.8z" fill="#FF5F00"/></svg>
          <!-- PayPal text -->
          <span class="text-[10px] text-forest-400 font-semibold tracking-wide">PayPal</span>
        </div>
      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Brand tagline", "default": "Your premium destination for authentic international groceries in Frankfurt am Main." },
    { "type": "text", "id": "address", "label": "Address", "default": "Frankfurt am Main, Germany" },
    { "type": "text", "id": "phone",             "label": "Phone number" },
    { "type": "text", "id": "whatsapp_number",   "label": "WhatsApp number (e.g. +4969123456)" },
    { "type": "link_list", "id": "footer_shop_menu", "label": "Shop menu" },
    { "type": "link_list", "id": "footer_info_menu", "label": "Info menu" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" }
  ]
}
{% endschema %}
