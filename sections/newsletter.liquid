<section class="py-16 bg-forest-800 relative overflow-hidden">

  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-72 h-72 bg-forest-700/50 rounded-full -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-56 h-56 bg-saffron-500/10 rounded-full translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

  <div class="relative max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <p class="text-xs font-semibold uppercase tracking-widest text-saffron-400 mb-3">Stay in the loop</p>

    <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
      {{ section.settings.heading | default: "Get Weekly Deals & Recipes" }}
    </h2>

    <p class="text-forest-300 text-base leading-relaxed mb-8">
      {{ section.settings.subtext | default: "Join 5,000+ subscribers who get exclusive offers, new arrivals, and authentic recipes every week." }}
    </p>

    <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input type="email" placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}"
             class="flex-1 px-4 py-3 text-sm bg-forest-700 border border-forest-600 rounded-xl text-white placeholder-forest-400 focus:outline-none focus:ring-2 focus:ring-saffron-400 focus:border-transparent transition-all"
             required>
      <button type="submit"
              class="px-6 py-3 bg-saffron-500 hover:bg-saffron-600 text-white font-semibold text-sm rounded-xl transition-colors flex-shrink-0">
        {{ section.settings.button_label | default: "Subscribe" }}
      </button>
    </form>

    <p class="mt-4 text-xs text-forest-400">
      No spam, unsubscribe anytime. We respect your privacy.
    </p>

  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get Weekly Deals & Recipes" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Join 5,000+ subscribers who get exclusive offers, new arrivals, and authentic recipes every week." },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "your@email.com" },
    { "type": "text", "id": "button_label", "label": "Button text", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
