{%- liquid
  assign messages = "🌿 Fresh International Groceries,🛒 Free delivery over €50,🌍 200+ authentic products,📍 Frankfurt am Main,🥘 Afghan · Turkish · Indian · Arabic,🌶️ Fresh spices daily,🫙 Specialty pantry staples,🍬 International sweets & snacks" | split: ","
  assign categories = "spices-masalas|Spices & Masalas|🌶️,rice-grains|Rice & Grains|🍚,canned-goods|Canned Goods|🥫,tea-coffee|Tea & Coffee|☕,snacks-sweets|Snacks & Sweets|🍬,fresh-produce|Fresh Produce|🥬,dairy-refrigerated|Dairy & Refrigerated|🧈,beverages|Beverages|🧃" | split: ","
-%}

<!-- ── Announcement Marquee ── -->
<div class="bg-forest-900 overflow-hidden py-1.5 relative">
  <div class="marquee-container">
    <div class="marquee-track">
      {%- for i in (1..2) -%}
        <span class="marquee-content text-white text-xs whitespace-nowrap" {% if i == 2 %}aria-hidden="true"{% endif %}>
          {%- for msg in messages -%}
            <span>{{ msg }}</span>
            <span class="text-saffron-400 mx-3">•</span>
          {%- endfor -%}
        </span>
      {%- endfor -%}
    </div>
  </div>
</div>

<header class="bg-white sticky top-0 z-40 shadow-sm" id="site-header">

  <!-- ── ROW 1: Logo | Search | Auth | Cart ── -->
  <div class="border-b border-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 h-16 lg:h-[70px]">

        <!-- Logo -->
        <a href="{{ routes.root_url }}" class="flex-shrink-0">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 240 }}" alt="{{ shop.name }}" class="h-10 w-auto object-contain">
          {%- else -%}
            <img src="{{ 'logo.jpeg' | asset_url }}" alt="{{ shop.name }}" class="h-10 w-auto object-contain">
          {%- endif -%}
        </a>

        <!-- Search bar -->
        <div class="flex-1 hidden md:flex max-w-2xl">
          <form action="{{ routes.search_url }}" method="get" class="flex w-full rounded-lg border-2 border-forest-700 overflow-hidden" role="search">
            <input type="search" name="q" placeholder="Search for products you want"
                   class="flex-1 px-4 py-2.5 text-sm text-stone-700 placeholder:text-stone-400 outline-none bg-white"
                   autocomplete="off">
            <button type="submit" class="px-5 bg-forest-700 hover:bg-forest-800 text-white font-semibold text-sm flex items-center gap-2 transition-colors flex-shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Search
            </button>
          </form>
        </div>

        <!-- Delivery location -->
        <div class="hidden xl:flex items-center gap-2 text-stone-600 border-l border-stone-100 pl-4 flex-shrink-0">
          <svg class="w-4 h-4 text-forest-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <div>
            <p class="text-[10px] text-stone-400 leading-none">Delivering to</p>
            <p class="text-sm font-semibold text-stone-800 leading-none mt-0.5">Frankfurt, DE</p>
          </div>
        </div>

        <!-- Auth -->
        <div class="hidden lg:flex items-center gap-1 flex-shrink-0">
          <svg class="w-4 h-4 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <a href="{{ routes.account_url }}" class="text-sm font-medium text-stone-700 hover:text-forest-700 whitespace-nowrap transition-colors">
            Log In / Sign Up
          </a>
        </div>

        <!-- Cart -->
        <button id="open-cart" aria-label="Open cart"
                class="relative flex items-center gap-2 bg-forest-700 hover:bg-forest-800 text-white rounded-lg px-3.5 py-2 transition-colors ml-auto lg:ml-0 flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          <span class="hidden sm:inline text-sm font-semibold">Cart</span>
          <span id="cart-badge" data-cart-count
                class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-saffron-500 text-white text-[10px] font-bold rounded-full items-center justify-center
                {%- if cart.item_count > 0 %} flex{%- else %} hidden{%- endif %}">
            {{ cart.item_count }}
          </span>
        </button>

        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-btn" aria-label="Menu"
                class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg hover:bg-warm-100 transition-colors">
          <svg class="w-5 h-5" id="hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg class="w-5 h-5 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- ── ROW 2: Categories dropdown + Quick links ── -->
  <div class="hidden lg:block bg-white border-b border-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center">

        <!-- Categories mega-button + dropdown -->
        <div class="relative" id="cat-dropdown-wrap">
          <button id="cat-btn"
                  class="flex items-center gap-2 px-4 py-3 bg-forest-700 text-white font-semibold text-sm hover:bg-forest-800 transition-colors h-full">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            Categories
            <svg class="w-3.5 h-3.5 transition-transform duration-200" id="cat-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <!-- Dropdown panel -->
          <div id="cat-panel"
               class="absolute top-full left-0 w-64 bg-white shadow-xl border border-stone-100 rounded-b-xl z-50 hidden">
            {%- for cat_str in categories -%}
              {%- assign cat_parts = cat_str | split: "|" -%}
              <a href="/collections/{{ cat_parts[0] }}"
                 class="flex items-center justify-between px-4 py-3 text-sm text-stone-700 hover:bg-forest-50 hover:text-forest-700 transition-colors border-b border-stone-50 last:border-0">
                <span class="flex items-center gap-3">
                  <span class="text-lg">{{ cat_parts[2] }}</span>
                  {{ cat_parts[1] }}
                </span>
                <svg class="w-3.5 h-3.5 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            {%- endfor -%}
            <a href="{{ routes.collections_url }}"
               class="flex items-center justify-center gap-1.5 px-4 py-3 text-xs font-semibold text-forest-700 hover:bg-forest-50 transition-colors rounded-b-xl">
              View all categories →
            </a>
          </div>
        </div>

        <!-- Quick links -->
        <nav class="flex items-center">
          <a href="/collections/all?sort_by=best-selling"
             class="flex items-center gap-1.5 px-4 py-3 text-sm font-medium text-stone-700 hover:text-forest-700 hover:bg-forest-50 transition-colors whitespace-nowrap">
            <svg class="w-3.5 h-3.5 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            Bestsellers
          </a>
          <a href="/collections/new-arrivals"
             class="flex items-center gap-1.5 px-4 py-3 text-sm font-medium text-stone-700 hover:text-forest-700 hover:bg-forest-50 transition-colors whitespace-nowrap">
            <svg class="w-3.5 h-3.5 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
            New Arrivals
          </a>
          <a href="/collections/on-sale"
             class="flex items-center gap-1.5 px-4 py-3 text-sm font-medium text-stone-700 hover:text-forest-700 hover:bg-forest-50 transition-colors whitespace-nowrap">
            <svg class="w-3.5 h-3.5 text-spice-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            On Sale
          </a>
          <a href="/collections/bundles"
             class="flex items-center gap-1.5 px-4 py-3 text-sm font-medium text-stone-700 hover:text-forest-700 hover:bg-forest-50 transition-colors whitespace-nowrap">
            <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            Bundles
          </a>
          <a href="/collections/gift-hampers"
             class="flex items-center gap-1.5 px-4 py-3 text-sm font-medium text-stone-700 hover:text-forest-700 hover:bg-forest-50 transition-colors whitespace-nowrap">
            <svg class="w-3.5 h-3.5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
            </svg>
            Gift Hampers
          </a>
          <a href="/collections/on-sale"
             class="flex items-center gap-1.5 px-4 py-3 text-sm font-medium text-stone-700 hover:text-forest-700 hover:bg-forest-50 transition-colors whitespace-nowrap">
            <svg class="w-3.5 h-3.5 text-saffron-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            April Offers
            <span class="ml-1 px-1.5 py-0.5 bg-spice-500 text-white text-[9px] font-bold rounded uppercase">Hot</span>
          </a>
        </nav>

      </div>
    </div>
  </div>

  <!-- ── ROW 3: Category icon strip ── -->
  <div class="hidden lg:block bg-white border-b border-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-start overflow-x-auto scrollbar-hide py-2">
        {%- for cat_str in categories -%}
          {%- assign cat_parts = cat_str | split: "|" -%}
          <a href="/collections/{{ cat_parts[0] }}"
             class="flex flex-col items-center gap-1.5 px-4 py-1.5 group flex-shrink-0 hover:bg-forest-50 rounded-lg transition-colors">
            <span class="text-2xl">{{ cat_parts[2] }}</span>
            <span class="text-[11px] font-medium text-stone-600 group-hover:text-forest-700 text-center leading-tight whitespace-nowrap transition-colors">
              {{ cat_parts[1] }}
            </span>
          </a>
        {%- endfor -%}
        <a href="{{ routes.collections_url }}"
           class="flex flex-col items-center gap-1.5 px-4 py-1.5 group flex-shrink-0 hover:bg-forest-50 rounded-lg transition-colors">
          <span class="text-2xl">🔍</span>
          <span class="text-[11px] font-medium text-stone-600 group-hover:text-forest-700 text-center leading-tight whitespace-nowrap transition-colors">All Categories</span>
        </a>
      </div>
    </div>
  </div>

  <!-- ── Mobile Menu ── -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-stone-100 shadow-lg">

    <!-- Mobile Search -->
    <div class="px-4 py-3 border-b border-stone-100">
      <form action="{{ routes.search_url }}" method="get" class="flex rounded-lg border-2 border-forest-700 overflow-hidden" role="search">
        <input type="search" name="q" placeholder="Search products…"
               class="flex-1 px-3 py-2.5 text-sm outline-none" autocomplete="off">
        <button type="submit" class="px-4 bg-forest-700 text-white">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>
      </form>
    </div>

    <!-- Mobile Category icons grid -->
    <div class="px-4 py-3 border-b border-stone-100">
      <div class="grid grid-cols-4 gap-2">
        {%- for cat_str in categories -%}
          {%- assign cat_parts = cat_str | split: "|" -%}
          <a href="/collections/{{ cat_parts[0] }}"
             class="flex flex-col items-center gap-1 p-2 rounded-xl hover:bg-forest-50 transition-colors">
            <span class="text-2xl">{{ cat_parts[2] }}</span>
            <span class="text-[10px] text-stone-500 text-center leading-tight">{{ cat_parts[1] | split: ' ' | first }}</span>
          </a>
        {%- endfor -%}
      </div>
    </div>

    <!-- Mobile Quick Links -->
    <nav class="divide-y divide-stone-50">
      <a href="{{ routes.root_url }}" class="flex items-center justify-between px-4 py-3.5 text-sm font-medium text-stone-700 hover:text-forest-700">
        Home
        <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="{{ routes.all_products_collection_url }}" class="flex items-center justify-between px-4 py-3.5 text-sm font-medium text-stone-700 hover:text-forest-700">
        Shop All
        <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/collections/all?sort_by=best-selling" class="flex items-center justify-between px-4 py-3.5 text-sm font-medium text-stone-700 hover:text-forest-700">
        Bestsellers
        <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/collections/new-arrivals" class="flex items-center justify-between px-4 py-3.5 text-sm font-medium text-stone-700 hover:text-forest-700">
        New Arrivals
        <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/collections/on-sale" class="flex items-center justify-between px-4 py-3.5 text-sm font-medium text-stone-700 hover:text-forest-700">
        On Sale
        <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/collections/gift-hampers" class="flex items-center justify-between px-4 py-3.5 text-sm font-medium text-stone-700 hover:text-forest-700">
        Gift Hampers
        <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="{{ routes.account_url }}" class="flex items-center justify-between px-4 py-3.5 text-sm font-medium text-stone-700 hover:text-forest-700">
        My Account
        <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </nav>

  </div>

</header>

<script>
  // Mobile menu toggle
  (function() {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var ham = document.getElementById('hamburger-icon');
    var close = document.getElementById('close-icon');
    if (btn && menu) {
      btn.addEventListener('click', function() {
        var isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden', isOpen);
        ham.classList.toggle('hidden', !isOpen);
        close.classList.toggle('hidden', isOpen);
      });
    }

    // Categories dropdown toggle
    var catBtn = document.getElementById('cat-btn');
    var catPanel = document.getElementById('cat-panel');
    var catChevron = document.getElementById('cat-chevron');
    var catWrap = document.getElementById('cat-dropdown-wrap');
    if (catBtn && catPanel) {
      catWrap.addEventListener('mouseenter', function() {
        catPanel.classList.remove('hidden');
        catChevron.style.transform = 'rotate(180deg)';
      });
      catWrap.addEventListener('mouseleave', function() {
        catPanel.classList.add('hidden');
        catChevron.style.transform = 'rotate(0deg)';
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
