{%- liquid
  assign menu = linklists[section.settings.menu]
  assign messages = "🌿 Fresh International Groceries,🛒 Free delivery over €50,🌍 200+ authentic products,📍 Frankfurt am Main,🥘 Afghan · Turkish · Indian · Arabic,🌶️ Fresh spices daily,🫙 Specialty pantry staples,🍬 International sweets & snacks" | split: ","
-%}

<!-- Announcement Marquee -->
<div class="bg-forest-900 overflow-hidden py-2 relative">
  <div class="marquee-container">
    <div class="marquee-track">
      {%- for i in (1..2) -%}
        <span class="marquee-content text-white text-xs whitespace-nowrap" {% if i == 2 %}aria-hidden="true"{% endif %}>
          {%- for msg in messages -%}
            <span>{{ msg }}</span>
            <span class="text-saffron-400">•</span>
          {%- endfor -%}
        </span>
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- Main Header -->
<header class="bg-white border-b border-warm-200 sticky top-0 z-40" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="{{ routes.root_url }}" class="flex items-center gap-2 flex-shrink-0">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="h-10 w-auto">
        {%- else -%}
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-forest-700 rounded-lg flex items-center justify-center">
              <span class="text-white font-bold text-sm">A</span>
            </div>
            <div>
              <p class="font-display font-bold text-forest-900 text-base leading-none">A&amp;A</p>
              <p class="text-[9px] text-stone-400 uppercase tracking-widest leading-none mt-0.5">International Supermarkt</p>
            </div>
          </div>
        {%- endif -%}
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-0.5" role="navigation" aria-label="Main navigation">
        {%- for link in menu.links -%}
          {%- if link.links != blank -%}
            <div class="relative group">
              <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-stone-600 hover:text-forest-700 rounded-lg hover:bg-warm-100 transition-all">
                {{ link.title }}
                <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="absolute top-full left-0 mt-1 w-52 bg-white rounded-2xl shadow-card-hover border border-warm-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-2">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="block px-4 py-2.5 text-sm text-stone-600 hover:text-forest-700 hover:bg-warm-50 transition-colors">
                    {{ child.title }}
                  </a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}"
               class="px-3 py-2 text-sm font-medium rounded-lg transition-all
               {%- if link.active %} text-forest-700 bg-forest-50{%- else %} text-stone-600 hover:text-forest-700 hover:bg-warm-100{%- endif %}">
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      <!-- Action Icons -->
      <div class="flex items-center gap-1">

        <!-- Search -->
        <button id="search-toggle" aria-label="Search" class="p-2 text-stone-500 hover:text-forest-700 hover:bg-warm-100 rounded-full transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>

        <!-- Account -->
        <a href="{{ routes.account_url }}" aria-label="Account" class="hidden sm:flex p-2 text-stone-500 hover:text-forest-700 hover:bg-warm-100 rounded-full transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </a>

        <!-- Cart -->
        <button id="open-cart" aria-label="Open cart" class="relative p-2 text-stone-500 hover:text-forest-700 hover:bg-warm-100 rounded-full transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          <span id="cart-badge" data-cart-count
                class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-saffron-500 text-white text-[10px] font-bold rounded-full items-center justify-center
                {%- if cart.item_count > 0 %} flex{%- else %} hidden{%- endif %}">
            {{ cart.item_count }}
          </span>
        </button>

        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-btn" aria-label="Menu" class="lg:hidden p-2 text-stone-500 hover:text-forest-700 hover:bg-warm-100 rounded-full transition-all">
          <svg class="w-5 h-5" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Search Bar -->
  <div id="search-bar" class="hidden border-t border-warm-100 bg-white">
    <div class="max-w-2xl mx-auto px-4 py-3">
      <form action="{{ routes.search_url }}" method="get" role="search">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="search" name="q" placeholder="Search products, brands, categories…"
                 class="w-full pl-10 pr-4 py-2.5 text-sm bg-warm-50 border border-warm-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-forest-600 focus:border-transparent transition-all"
                 autocomplete="off">
        </div>
      </form>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-warm-100 bg-white">
    <nav class="px-4 py-3 space-y-0.5">
      {%- for link in menu.links -%}
        <a href="{{ link.url }}"
           class="flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all
           {%- if link.active %} text-forest-700 bg-forest-50{%- else %} text-stone-600 hover:text-forest-700 hover:bg-warm-100{%- endif %}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    }
  ]
}
{% endschema %}
