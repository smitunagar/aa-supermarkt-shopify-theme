<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#15803d">

  <title>
    {%- if page_title == blank -%}{{ shop.name }}{%- else -%}{{ page_title }} | {{ shop.name }}{%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            // Clean Emerald Green brand palette
            forest: {
              50: '#f0fdf4', 100: '#dcfce7', 200: '#bbf7d0', 300: '#86efac',
              400: '#4ade80', 500: '#22c55e', 600: '#16a34a', 700: '#15803d',
              800: '#166534', 900: '#14532d', 950: '#052e16',
            },
            saffron: {
              50: '#fffbeb', 100: '#fef3c7', 200: '#fde68a', 300: '#fcd34d',
              400: '#fbbf24', 500: '#f59e0b', 600: '#d97706', 700: '#b45309',
              800: '#92400e', 900: '#78350f',
            },
            spice: {
              50: '#fef2f2', 100: '#fee2e2', 200: '#fecaca', 300: '#fca5a5',
              400: '#f87171', 500: '#ef4444', 600: '#dc2626', 700: '#b91c1c',
              800: '#991b1b', 900: '#7f1d1d',
            },
            warm: {
              50: '#fafaf9', 100: '#f5f5f4', 200: '#e7e5e4', 300: '#d6d3d1',
              400: '#a8a29e', 500: '#78716c', 600: '#57534e', 700: '#44403c',
              800: '#292524', 900: '#1c1917',
            },
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            display: ['Playfair Display', 'Georgia', 'serif'],
          },
          boxShadow: {
            'card': '0 2px 12px 0 rgba(0,0,0,0.06), 0 1px 3px 0 rgba(0,0,0,0.04)',
            'card-hover': '0 8px 30px 0 rgba(0,0,0,0.10), 0 2px 8px 0 rgba(0,0,0,0.06)',
          },
        },
      },
    }
  </script>

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>

<body class="font-sans bg-warm-50 text-stone-800 antialiased">

  {%- section 'header' -%}

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- Cart Drawer -->
  <div id="cart-drawer" aria-hidden="true" class="fixed inset-0 z-50 pointer-events-none">
    <div id="cart-overlay" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
    <div id="cart-panel" class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl flex flex-col translate-x-full transition-transform duration-300 ease-out">
      <div class="flex items-center justify-between p-5 border-b border-warm-200">
        <h2 class="font-semibold text-stone-800">Your Cart (<span id="cart-count-label">{{ cart.item_count }}</span>)</h2>
        <button id="close-cart" class="p-2 hover:bg-warm-100 rounded-full transition-colors" aria-label="Close cart">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div id="cart-items-container" class="flex-1 overflow-y-auto p-5 space-y-4">
        {%- render 'cart-items' -%}
      </div>
      <div class="p-5 border-t border-warm-200">
        <div class="flex justify-between items-center mb-4">
          <span class="font-semibold text-stone-800">Total</span>
          <span class="font-bold text-xl text-forest-700" id="cart-total-price">{{ cart.total_price | money }}</span>
        </div>
        <a href="{{ routes.cart_url }}/checkout" class="block w-full py-3.5 bg-forest-700 hover:bg-forest-800 text-white font-semibold text-center rounded-2xl transition-colors">
          Proceed to Checkout
        </a>
        <a href="{{ routes.cart_url }}" class="block w-full py-2.5 text-center text-sm text-stone-500 hover:text-forest-700 mt-2 transition-colors">
          View Full Cart
        </a>
      </div>
    </div>
  </div>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
